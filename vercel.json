{
    "version": 2,
    "outputDirectory": "dist",
    "routes": [
        {
            "src": "/api/go/(.*)",
            "dest": "/server/api/hello.go"
        },
        {
            "src": "/api/(.*)",
            "dest": "/server/api/index.ts"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "functions": {
        "server/api/index.ts": {
            "runtime": "@vercel/node"
        },
        "server/api/*.go": {
            "runtime": "@vercel/go"
        }
    }
}